# ─────────────────────────────────────────────────────────────────
# SkillMap AI — Backend Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────
APP_NAME="SkillMap AI"
APP_ENV=development
DEBUG=True

# ── Database ──────────────────────────────────────────────────────
# Format: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg2://skillmap_user:your_password@localhost:5432/skillmap_db

# ── JWT ───────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-me-with-32-char-hex-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# ── CORS ──────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── YouTube Data API v3 (for later) ───────────────────────────────
YOUTUBE_API_KEY=your-youtube-data-api-v3-key

# ── AI / Gemini (for later) ───────────────────────────────────────
GOOGLE_API_KEY=your-gemini-api-key
